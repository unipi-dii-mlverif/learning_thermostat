{
  "fmus": {
    "{Plant}": "Plant.fmu",
    "{Controller}": "Controller.fmu",
    "{Room}": "Room.fmu",
    "{Supervisor}": "Supervisor.fmu",
    "{KalmanFilter}": "KalmanFilter.fmu",
    "{ThermostatML}": "ThermostatML.fmu"
  },
  "connections": {
    "{Plant}.PlantInstance.T_bair_out": [
      "{Controller}.ControllerInstance.T_bair_in",
      "{Supervisor}.SupervisorInstance.T_bair_plant_in",
      "{KalmanFilter}.KalmanFilterInstance.T_bair_in",
      "{ThermostatML}.ThermostatMLInstance.T_bair_in"
    ],
    "{Controller}.ControllerInstance.heater_on_out": [
      "{Plant}.PlantInstance.heater_on_in",
      "{Supervisor}.SupervisorInstance.heater_on_in",
      "{KalmanFilter}.KalmanFilterInstance.heater_on_in"
    ],
    "{Supervisor}.SupervisorInstance.C_out": [
      "{Controller}.ControllerInstance.C_in"
    ],
    "{Supervisor}.SupervisorInstance.H_out": [
      "{Controller}.ControllerInstance.H_in"
    ],
    "{Supervisor}.SupervisorInstance.LL_out": [
      "{Controller}.ControllerInstance.LL_in"
    ],
    "{Supervisor}.SupervisorInstance.UL_out": [
      "{Controller}.ControllerInstance.UL_in"
    ],
    "{KalmanFilter}.KalmanFilterInstance.T_bair_out": [
      "{Supervisor}.SupervisorInstance.T_bair_in"
    ],
    "{KalmanFilter}.KalmanFilterInstance.T_heater_out": [
      "{Supervisor}.SupervisorInstance.T_heater_in"
    ],
    "{Room}.RoomInstance.T_room_out": [
      "{Plant}.PlantInstance.T_room_in",
      "{Supervisor}.SupervisorInstance.T_room_in",
      "{KalmanFilter}.KalmanFilterInstance.T_room_in"
    ]
  },
  "parameters": {
    "{Plant}.PlantInstance.delay": -1
  },
  "algorithm": {
    "type": "fixed-step",
    "size": 5
  },
  "modelSwaps": {
    "ControllerInstance": {
      "swapInstance": "ThermostatMLInstance",
      "stepCondition": "(true)",
      "swapCondition": "(ThermostatMLInstance.has_learnt)",
      "swapConnections": {
        "{Plant}.PlantInstance.T_bair_out": [
          "{ThermostatML}.ThermostatMLInstance.T_bair_in"
        ],
        "{ThermostatML}.ThermostatMLInstance.heater_on_out": [
          "{Plant}.PlantInstance.heater_on_in",
          "{Supervisor}.SupervisorInstance.heater_on_in",
          "{KalmanFilter}.KalmanFilterInstance.heater_on_in"
        ],
        "{Supervisor}.SupervisorInstance.C_out": [
          "{ThermostatML}.ThermostatMLInstance.C_in"
        ],
        "{Supervisor}.SupervisorInstance.H_out": [
          "{ThermostatML}.ThermostatMLInstance.H_in"
        ],
        "{Supervisor}.SupervisorInstance.LL_out": [
          "{ThermostatML}.ThermostatMLInstance.LL_in"
        ],
        "{Supervisor}.SupervisorInstance.UL_out": [
          "{ThermostatML}.ThermostatMLInstance.UL_in"
        ],
        "{Controller}.ControllerInstance.heater_on_out": [
          "{ThermostatML}.ThermostatMLInstance.heater_on_in"
        ]
      }
    }
  },
  "modelTransfers": {
    "PlantInstance": "PlantInstance",
    "RoomInstance": "RoomInstance",
    "SupervisorInstance": "SupervisorInstance",
    "KalmanFilterInstance": "KalmanFilterInstance"
  }
}
